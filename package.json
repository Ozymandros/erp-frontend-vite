{
  "name": "erp-frontend-vite",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "vite",
    "dev": "vite",
    "build": "tsc && vite build",
    "build:vite": "vite build",
    "lint": "pnpm exec eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "type-check": "npx tsc --noEmit",
    "preview": "vite preview",
    "test": "pnpm type-check && pnpm lint && pnpm exec vitest",
    "test:ui": "pnpm exec vitest --ui",
    "test:e2e": "pnpm exec playwright test",
    "test:e2e:headed": "pnpm exec playwright test --headed",
    "test:e2e:report": "pnpm exec playwright show-report",
    "test:coverage": "pnpm exec vitest run --coverage",
    "check:all": "pnpm type-check & pnpm lint & pnpm test:coverage"
  },
  "dependencies": {
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/themes": "^3.3.0",
    "axios": "^1.16.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "next-themes": "^0.4.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.3",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@rollup/rollup-linux-x64-gnu": "4.60.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "happy-dom": "^20.9.0",
    "jsdom": "^27.4.0",
    "playwright-core": "^1.59.1",
    "postcss": "^8.5.13",
    "tailwindcss": "^3.4.19",
    "testcontainers": "^11.14.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.2",
    "vitest": "^4.1.5"
  },
  "optionalDependencies": {
    "@rollup/rollup-darwin-arm64": "4.60.2",
    "@rollup/rollup-darwin-x64": "4.60.2",
    "@rollup/rollup-linux-x64-gnu": "4.60.2",
    "@rollup/rollup-win32-x64-msvc": "4.60.2"
